{
  "services": {
    "client": {
      "type": "client",
      "next": ["node4", "node5", "node6"],
      "client_workflow": "default"
    },
    "middle": {
      "type": "server",
      "clients": ["node1", "node2", "node3"],
      "nodes": ["node4", "node5", "node6"],
      "exec_workflow": "middle",
      "shimQuorumSize": 2,
      "verifyResponseQuorumSize": 1,
      "execVerifyQuorumSize": 2,
      "phaseQuorumSize": 2,
      "expectedExecVotes": 3
    },
    "backend": {
      "type": "server",
      "clients": ["node4", "node5", "node6"],
      "nodes": ["node7", "node8", "node9"],
      "exec_workflow": "backend",
      "shimQuorumSize": 2,
      "verifyResponseQuorumSize": 1,
      "execVerifyQuorumSize": 2,
      "phaseQuorumSize": 2,
      "expectedExecVotes": 3
    }
  },
  "nodes": {
    "node1": {
      "service": "client"
    },
    "node2": {
      "service": "client"
    },
    "node3": {
      "service": "client"
    },
    "node4": {
      "service": "middle",
      "is_primary_batcher": true
    },
    "node5": {
      "service": "middle",
      "is_primary_batcher": false
    },
    "node6": {
      "service": "middle",
      "is_primary_batcher": false
    },
    "node7": {
      "service": "backend",
      "is_primary_batcher": true
    },
    "node8": {
      "service": "backend",
      "is_primary_batcher": false
    },
    "node9": {
      "service": "backend",
      "is_primary_batcher": false
    }
  }
}
