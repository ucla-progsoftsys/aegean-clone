{
  "services": {
    "oha_client": {
      "type": "oha_client",
      "next": ["node1", "node2", "node3"],
      "client_workflow": "supersimple_oha_client"
    },
    "server": {
      "type": "server",
      "clients": ["node0"],
      "nodes": ["node1", "node2", "node3"],
      "exec_workflow": "supersimple_server",
      "init_state_workflow": "supersimple_default",
      "shimQuorumSize": 1,
      "verifyResponseQuorumSize": 1,
      "execVerifyQuorumSize": 2,
      "phaseQuorumSize": 2,
      "expectedExecVotes": 3
    }
  },
  "nodes": {
    "node0": {
      "service": "oha_client"
    },
    "node1": {
      "service": "server",
      "is_primary_batcher": true
    },
    "node2": {
      "service": "server",
      "is_primary_batcher": false
    },
    "node3": {
      "service": "server",
      "is_primary_batcher": false
    }
  }
}
