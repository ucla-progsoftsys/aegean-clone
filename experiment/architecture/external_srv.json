{
  "services": {
    "oha_client": {
      "type": "oha_client",
      "next": ["node2", "node3", "node4"],
      "client_workflow": "external_srv_oha_client"
    },
    "server": {
      "type": "server",
      "clients": ["node1"],
      "nodes": ["node2", "node3", "node4"],
      "exec_workflow": "external_srv_server",
      "init_state_workflow": "external_srv_default",
      "shimQuorumSize": 1,
      "verifyResponseQuorumSize": 1,
      "execVerifyQuorumSize": 2,
      "phaseQuorumSize": 2,
      "expectedExecVotes": 3
    },
    "external_service": {
      "type": "external_service",
      "external_service_workflow": "external_srv_external_service",
      "external_service_init_state": "external_srv_default"
    }
  },
  "nodes": {
    "node1": {
      "service": "oha_client"
    },
    "node2": {
      "service": "server",
      "is_primary_batcher": true
    },
    "node3": {
      "service": "server",
      "is_primary_batcher": false
    },
    "node4": {
      "service": "server",
      "is_primary_batcher": false
    },
    "node5": {
      "service": "external_service",
      "is_primary_batcher": true
    }
  }
}
